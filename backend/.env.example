# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=CareerForge
APP_ENV=development
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ─────────────────────────────────────────────────────────────────
# Used by SQLAlchemy async engine (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/careerforge
# Used by Alembic migrations (sync psycopg2 driver)
SYNC_DATABASE_URL=postgresql://postgres:password@db:5432/careerforge

# ─── Ollama  ──────────────────────────────────────────────────────────────────
# REQUIRED — all agents run locally on Ollama (no API key needed)
# Download Ollama: https://ollama.com/download
# Then pull the model: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ─── GitHub (Optional) ────────────────────────────────────────────────────────
# Without this, GitHub skill verification is skipped (gracefully)
# Create at: https://github.com/settings/tokens  (read:user, public_repo scopes)
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
